    "MemDataWidth"
  ],
  "clock": "clk_i",
  "reset": "rst_ni",
  "reset_polarity": "active_low",
  "pkg_types": {},
  "connectivity": [
    {
      "lhs": "data_addr",
      "rhs": "adder_result_ex_i",
      "rhs_signals": [
        "adder_result_ex_i"
      ]
    },
    {
      "lhs": "data_offset",
      "rhs": "data_addr[1:0]",
      "rhs_signals": [
        "data_addr"
      ]
    },
    {
      "lhs": "addr_last_d",
      "rhs": "addr_incr_req_o ? data_addr_w_aligned : data_addr",
      "rhs_signals": [
        "addr_incr_req_o",
        "data_addr_w_aligned",
        "data_addr"
      ]
    },
    {
      "lhs": "data_intg_err",
      "rhs": "|ecc_err",
      "rhs_signals": [
        "ecc_err"
      ]
    },
    {
      "lhs": "data_intg_err",
      "rhs": "1'b0",
      "rhs_signals": []
    },
    {
      "lhs": "split_misaligned_access",
      "rhs": "((lsu_type_i == 2'b00) && (data_offset != 2'b00)) || \n      ((lsu_type_i == 2'b01) && (data_offset == 2'b11))",
      "rhs_signals": [
        "lsu_type_i",
        "data_offset"
      ]
    },
    {
      "lhs": "lsu_req_done_o",
      "rhs": "(lsu_req_i | (ls_fsm_cs != IDLE)) & (ls_fsm_ns == IDLE)",
      "rhs_signals": [
        "lsu_req_i"
      ]
    },
    {
      "lhs": "data_or_pmp_err",
      "rhs": "lsu_err_q | data_bus_err_i | pmp_err_q",
      "rhs_signals": [
        "data_bus_err_i"
      ]
    },
    {
      "lhs": "lsu_resp_valid_o",
      "rhs": "(data_rvalid_i | pmp_err_q) & (ls_fsm_cs == IDLE)",
      "rhs_signals": [
        "data_rvalid_i"
      ]
    },
    {
      "lhs": "lsu_rdata_valid_o",
      "rhs": "(ls_fsm_cs == IDLE) & data_rvalid_i & ~data_or_pmp_err & ~data_we_q & ~data_intg_err",
      "rhs_signals": [
        "data_rvalid_i",
        "data_we_q"
      ]
    },
    {
      "lhs": "lsu_rdata_o",
      "rhs": "data_rdata_ext",
      "rhs_signals": [
        "data_rdata_ext"
      ]
    },
    {
      "lhs": "data_addr_w_aligned",
      "rhs": "{data_addr[31:2], 2'b00}",
      "rhs_signals": [
        "data_addr"
      ]
    },
    {
      "lhs": "data_addr_o",
      "rhs": "data_addr_w_aligned",
      "rhs_signals": [
        "data_addr_w_aligned"
      ]
    },
    {
      "lhs": "data_we_o",
      "rhs": "lsu_we_i",
      "rhs_signals": [
        "lsu_we_i"
      ]
    },
    {
      "lhs": "data_be_o",
      "rhs": "data_be",
      "rhs_signals": [
        "data_be"
      ]
    },
    {
      "lhs": "data_wdata_o",
      "rhs": "data_wdata",
      "rhs_signals": [
        "data_wdata"
      ]
    },
    {
      "lhs": "addr_last_o",
      "rhs": "addr_last_q",
      "rhs_signals": []
    },
    {
      "lhs": "load_err_o",
      "rhs": "data_or_pmp_err & ~data_we_q & lsu_resp_valid_o",
      "rhs_signals": [
        "data_we_q",
        "lsu_resp_valid_o"
      ]
    },
    {
      "lhs": "store_err_o",
      "rhs": "data_or_pmp_err &  data_we_q & lsu_resp_valid_o",
      "rhs_signals": [
        "data_we_q",
        "lsu_resp_valid_o"
      ]
    },
    {
      "lhs": "load_resp_intg_err_o",
      "rhs": "data_intg_err & data_rvalid_i & ~data_we_q",
      "rhs_signals": [
        "data_rvalid_i",
        "data_we_q"
      ]
    },
    {
      "lhs": "store_resp_intg_err_o",
      "rhs": "data_intg_err & data_rvalid_i & data_we_q",
      "rhs_signals": [
        "data_rvalid_i",
        "data_we_q"
      ]
    },
    {
      "lhs": "busy_o",
      "rhs": "(ls_fsm_cs != IDLE)",
      "rhs_signals": []
    },
    {
      "lhs": "fcov_mis_rvalid_1",
      "rhs": "ls_fsm_cs inside {WAIT_RVALID_MIS, WAIT_RVALID_MIS_GNTS_DONE} &&\n                                data_rvalid_i",
      "rhs_signals": [
        "data_rvalid_i"
      ]
    },
    {
      "lhs": "fcov_mis_rvalid_2",
      "rhs": "ls_fsm_cs inside {IDLE} && fcov_mis_2_en_q && data_rvalid_i",
      "rhs_signals": [
        "data_rvalid_i"
      ]
    },
    {
      "lhs": "fcov_mis_2_en_d",
      "rhs": "fcov_mis_rvalid_2 ? 1'b0            :  \n                           fcov_mis_rvalid_1 ? 1'b1            :  \n                                               fcov_mis_2_en_q",
      "rhs_signals": []
    },
    {
      "lhs": "fcov_mis_bus_err_1_d",
      "rhs": "fcov_mis_rvalid_2                   ? 1'b0                 : \n                                fcov_mis_rvalid_1 && data_bus_err_i ? 1'b1                 : \n                                                                      fcov_mis_bus_err_1_q",
      "rhs_signals": [
        "data_bus_err_i"
      ]
    }
  ]
}