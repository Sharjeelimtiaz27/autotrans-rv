    {
      "lhs": "wb_valid_d",
      "rhs": "(en_wb_i & ready_wb_o) | (wb_valid_q & ~wb_done)",
      "rhs_signals": [
        "en_wb_i",
        "ready_wb_o",
        "wb_valid_q",
        "wb_done"
      ]
    },
    {
      "lhs": "wb_done",
