      "rhs": "~wb_valid_q | wb_done",
      "rhs_signals": [
        "wb_valid_q",
        "wb_done"
      ]
    },
    {
      "lhs": "rf_write_wb_o",
      "rhs": "wb_valid_q & (rf_we_wb_q | (wb_instr_type_q == WB_INSTR_LOAD))",
      "rhs_signals": [
        "wb_valid_q",
        "rf_we_wb_q"
      ]
    },
    {
      "lhs": "outstanding_load_wb_o",
