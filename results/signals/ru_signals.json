      "rhs": "wb_valid_q & wb_done",
      "rhs_signals": [
        "wb_valid_q",
        "wb_done"
      ]
    },
    {
      "lhs": "perf_instr_ret_wb_spec_o",
      "rhs": "wb_count_q",
      "rhs_signals": [
