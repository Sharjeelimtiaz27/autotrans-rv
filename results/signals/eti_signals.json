  "connectivity": [
    {
      "lhs": "load_err_d",
      "rhs": "load_err_i",
      "rhs_signals": [
        "load_err_i"
      ]
    },
    {
      "lhs": "store_err_d",
      "rhs": "store_err_i",
      "rhs_signals": [
        "store_err_i"
      ]
    },
    {
      "lhs": "ecall_insn",
      "rhs": "ecall_insn_i      & instr_valid_i",
      "rhs_signals": [
        "ecall_insn_i",
        "instr_valid_i"
      ]
    },
    {
      "lhs": "mret_insn",
      "rhs": "mret_insn_i       & instr_valid_i",
      "rhs_signals": [
        "mret_insn_i",
        "instr_valid_i"
      ]
    },
    {
      "lhs": "dret_insn",
      "rhs": "dret_insn_i       & instr_valid_i",
      "rhs_signals": [
        "dret_insn_i",
        "instr_valid_i"
      ]
    },
    {
      "lhs": "wfi_insn",
      "rhs": "wfi_insn_i        & instr_valid_i",
      "rhs_signals": [
        "wfi_insn_i",
        "instr_valid_i"
      ]
    },
    {
      "lhs": "ebrk_insn",
      "rhs": "ebrk_insn_i       & instr_valid_i",
      "rhs_signals": [
        "ebrk_insn_i",
        "instr_valid_i"
      ]
    },
    {
      "lhs": "csr_pipe_flush",
      "rhs": "csr_pipe_flush_i  & instr_valid_i",
      "rhs_signals": [
        "csr_pipe_flush_i",
        "instr_valid_i"
      ]
    },
    {
      "lhs": "instr_fetch_err",
      "rhs": "instr_fetch_err_i & instr_valid_i",
      "rhs_signals": [
        "instr_fetch_err_i",
        "instr_valid_i"
      ]
    },
    {
      "lhs": "illegal_insn_d",
      "rhs": "illegal_insn_i & (ctrl_fsm_cs != FLUSH)",
      "rhs_signals": [
        "illegal_insn_i"
      ]
    },
    {
      "lhs": "exc_req_d",
      "rhs": "(ecall_insn | ebrk_insn | illegal_insn_d | instr_fetch_err) &\n                     (ctrl_fsm_cs != FLUSH)",
      "rhs_signals": [
        "ecall_insn",
        "ebrk_insn",
        "instr_fetch_err"
      ]
    },
    {
      "lhs": "exc_req_lsu",
      "rhs": "store_err_i | load_err_i",
      "rhs_signals": [
        "store_err_i",
        "load_err_i"
      ]
    },
    {
      "lhs": "id_exception_o",
      "rhs": "exc_req_d & ~wb_exception_o",
      "rhs_signals": [
        "wb_exception_o"
      ]
    },
    {
      "lhs": "special_req_flush_only",
      "rhs": "wfi_insn | csr_pipe_flush",
      "rhs_signals": [
        "wfi_insn",
        "csr_pipe_flush"
      ]
    },
    {
      "lhs": "special_req_pc_change",
      "rhs": "mret_insn | dret_insn | exc_req_d | exc_req_lsu",
      "rhs_signals": [
        "mret_insn",
        "dret_insn",
        "exc_req_lsu"
      ]
    },
    {
      "lhs": "special_req",
      "rhs": "special_req_pc_change | special_req_flush_only",
      "rhs_signals": [
        "special_req_pc_change",
        "special_req_flush_only"
      ]
    },
    {
      "lhs": "id_wb_pending",
      "rhs": "instr_valid_i | ~ready_wb_i",
      "rhs_signals": [
        "instr_valid_i",
        "ready_wb_i"
      ]
    },
    {
      "lhs": "wb_exception_o",
      "rhs": "load_err_q | store_err_q | load_err_i | store_err_i",
      "rhs_signals": [
        "load_err_i",
        "store_err_i"
      ]
    },
    {
      "lhs": "wb_exception_o",
      "rhs": "1'b0",
      "rhs_signals": []
    },
    {
      "lhs": "entering_nmi",
      "rhs": "nmi_mode_d & ~nmi_mode_q",
      "rhs_signals": []
    },
    {
      "lhs": "mem_resp_intg_err_irq_pending_d",
      "rhs": "(mem_resp_intg_err_irq_pending_q & ~mem_resp_intg_err_irq_clear) | mem_resp_intg_err_irq_set",
      "rhs_signals": []
    },
    {
      "lhs": "irq_nm_int",
      "rhs": "mem_resp_intg_err_irq_pending_q",
      "rhs_signals": []
    },
    {
      "lhs": "irq_nm_int_cause",
      "rhs": "NMI_INT_CAUSE_ECC",
      "rhs_signals": []
    },
    {
      "lhs": "irq_nm_int_mtval",
      "rhs": "mem_resp_intg_err_addr_q",
      "rhs_signals": []
    },
    {
      "lhs": "unused_mem_resp_intg_err_i",
      "rhs": "mem_resp_intg_err_i",
      "rhs_signals": [
        "mem_resp_intg_err_i"
      ]
    },
    {
      "lhs": "irq_nm_int",
      "rhs": "1'b0",
      "rhs_signals": []
    },
    {
      "lhs": "irq_nm_int_cause",
      "rhs": "nmi_int_cause_e'(0)",
      "rhs_signals": []
    },
    {
      "lhs": "irq_nm_int_mtval",
      "rhs": "'0",
      "rhs_signals": []
    },
    {
      "lhs": "do_single_step_d",
      "rhs": "instr_valid_i ? ~debug_mode_q & debug_single_step_i : do_single_step_q",
      "rhs_signals": [
        "instr_valid_i",
        "debug_single_step_i",
        "do_single_step_q"
      ]
    },
    {
      "lhs": "enter_debug_mode_prio_d",
      "rhs": "(debug_req_i | do_single_step_d) & ~debug_mode_q",
      "rhs_signals": [
        "debug_req_i",
        "do_single_step_d"
      ]
    },
    {
      "lhs": "enter_debug_mode",
      "rhs": "enter_debug_mode_prio_d | (trigger_match_i & ~debug_mode_q)",
      "rhs_signals": [
        "enter_debug_mode_prio_d",
        "trigger_match_i"
      ]
    },
    {
      "lhs": "ebreak_into_debug",
      "rhs": "priv_mode_i == PRIV_LVL_M ? debug_ebreakm_i :\n                             priv_mode_i == PRIV_LVL_U ? debug_ebreaku_i :\n                                                         1'b0",
      "rhs_signals": [
        "priv_mode_i",
        "debug_ebreakm_i",
        "debug_ebreaku_i"
      ]
    },
    {
      "lhs": "irq_nm",
      "rhs": "irq_nm_ext_i | irq_nm_int",
      "rhs_signals": [
        "irq_nm_ext_i",
        "irq_nm_int"
      ]
    },
    {
      "lhs": "irq_enabled",
      "rhs": "csr_mstatus_mie_i | (priv_mode_i == PRIV_LVL_U)",
      "rhs_signals": [
        "csr_mstatus_mie_i",
        "priv_mode_i"
      ]
    },
    {
      "lhs": "handle_irq",
      "rhs": "~debug_mode_q & ~debug_single_step_i & ~nmi_mode_q &\n      (irq_nm | (irq_pending_i & irq_enabled))",
      "rhs_signals": [
        "debug_single_step_i",
        "irq_nm",
        "irq_pending_i",
        "irq_enabled"
      ]
    },
    {
      "lhs": "unused_irq_timer",
      "rhs": "irqs_i.irq_timer",
      "rhs_signals": [
        "irqs_i"
      ]
    },
    {
      "lhs": "debug_cause_d",
      "rhs": "trigger_match_i                    ? DBG_CAUSE_TRIGGER :\n                         ebrk_insn_prio & ebreak_into_debug ? DBG_CAUSE_EBREAK  :\n                         debug_req_i                        ? DBG_CAUSE_HALTREQ :\n                         do_single_step_d                   ? DBG_CAUSE_STEP    :\n                                                              DBG_CAUSE_NONE",
      "rhs_signals": [
        "trigger_match_i",
        "ebrk_insn_prio",
        "ebreak_into_debug",
        "debug_req_i",
        "do_single_step_d"
      ]
    },
    {
      "lhs": "debug_cause_o",
      "rhs": "debug_cause_q",
      "rhs_signals": []
    },
    {
      "lhs": "flush_id_o",
      "rhs": "flush_id",
      "rhs_signals": [
        "flush_id"
      ]
    },
    {
      "lhs": "debug_mode_o",
      "rhs": "debug_mode_q",
      "rhs_signals": []
    },
    {
      "lhs": "nmi_mode_o",
      "rhs": "nmi_mode_q",
      "rhs_signals": []
    },
    {
      "lhs": "stall",
      "rhs": "stall_id_i | stall_wb_i",
      "rhs_signals": [
        "stall_id_i",
        "stall_wb_i"
      ]
    },
    {
      "lhs": "id_in_ready_o",
      "rhs": "~stall & ~halt_if & ~retain_id",
      "rhs_signals": [
        "stall",
        "halt_if",
        "retain_id"
      ]
    },
    {
      "lhs": "instr_valid_clear_o",
      "rhs": "~(stall | retain_id) | flush_id",
      "rhs_signals": [
        "stall",
        "retain_id",
        "flush_id"
      ]
    },
    {
      "lhs": "rvfi_flush_next",
      "rhs": "ctrl_fsm_ns == FLUSH",
      "rhs_signals": []
    }
  ]
}